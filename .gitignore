# .gitignore — Professionnel pour Python + MLOps
# .gitignore — Professional for Python + MLOps

########################################
# Environnements virtuels / Virtual envs
########################################

# Common Python virtual environment folders
.venv/
venv/
env/
ENV/

# Pipenv / Poetry / pyenv
/.venv
Pipfile.lock
.python-version

# Environment variable files (secrets)
.env
.env.*

########################################
# Python & build artefacts
########################################

__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
eggs/
parts/
sdist/
develop-eggs/
pip-wheel-metadata/
wheelhouse/
htmlcov/
.pytest_cache/
.tox/
.nox/
.coverage
coverage.xml
*.cover
*.coveragerc
.hypothesis/
.mypy_cache/
.pyre/
.ruff_cache/

########################################
# MLOps / Data / Models / Logs
########################################

# Local MLflow tracking and artifacts
/mlruns/

# Typical model / artifact directories
/artifacts/
/models/
/checkpoints/
logs/
/reports/

# Local data and generated assets
*.csv
*.tsv
*.parquet
*.h5
*.hdf5
*.npz
*.npy
*.feather
*.dat
*.zip
*.tar
*.jsonl
*.log

# Serialized models and checkpoints
*.pkl
*.joblib
*.model
*.ckpt

########################################
# Jupyter
########################################

.ipynb_checkpoints/
*.ipynb_checkpoints

########################################
# IDEs, editors & OS files
########################################

.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~
.nfs*

########################################
# Docker & CI
########################################

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# CI caches and temporary files
.cache/

########################################
# Secrets, keys & credentials
########################################

*.pem
*.key
*.crt
credentials
secret*
secrets.yml

########################################
# Logs, runtime files
########################################

*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

########################################
# Misc
########################################

# OS generated files
Icon?

# Backup and temp files
*.bak
*.tmp
~*$

# End of file